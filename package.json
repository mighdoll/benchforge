{
  "name": "benchforge",
  "version": "0.1.11",
  "type": "module",
  "bin": "bin/benchforge",
  "files": [
    "bin",
    "dist",
    "src",
    "vendor"
  ],
  "scripts": {
    "build": "tsdown",
    "build:plots": "tsdown --config tsdown.plots.config.ts",
    "build:hosted": "run-s build:plots && bash scripts/build-hosted.sh",
    "example:node": "bin/benchforge examples/simple-cli.ts --gc-stats --alloc --view",
    "example:time": "bin/benchforge examples/simple-cli.ts --alloc --time-sample --view --skip-settle --filter quicksort",
    "example:bench": "bin/benchforge --url file://$PWD/examples/browser-bench/index.html --gc-stats --alloc --view",
    "example:heap": "node benchforge-browser/bin.mjs file://$PWD/examples/browser-heap/index.html --gc-stats --view",
    "example:lap": "bin/benchforge --url file://$PWD/examples/browser-lap/index.html --gc-stats --alloc --view",
    "fix": "biome check --fix --unsafe --error-on-warnings",
    "lint": "biome check --error-on-warnings",
    "prepublishOnly": "run-s lint build build:plots",
    "test": "pnpm --node-options=--expose-gc vitest --hideSkippedTests --exclude '**/*.e2e.test.ts'",
    "test:e2e": "pnpm --node-options=--expose-gc vitest run '.e2e.'",
    "test:once": "pnpm --node-options=--expose-gc vitest run --exclude '**/*.e2e.test.ts'",
    "typecheck": "tsgo",
    "prepush": "run-s fix typecheck test:once build build:plots",
    "publish:all": "pnpm publish && pnpm --filter benchforge-browser publish"
  },
  "publishConfig": {
    "bin": {
      "benchforge": "dist/bin/benchforge.mjs"
    },
    "exports": {
      ".": {
        "import": "./dist/index.mjs"
      }
    }
  },
  "exports": {
    ".": {
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "d3": "^7.9.0",
    "esbuild": "^0.27.3",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "shiki": "^4.0.2",
    "table": "^6.9.0",
    "yargs": "^18.0.0"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.3.0",
    "@types/yargs": "^17.0.35",
    "@typescript/native-preview": "7.0.0-dev.20260220.1",
    "npm-run-all": "^4.1.5",
    "playwright": "catalog:",
    "tsdown": "0.20.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
