{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["node"],

    "declaration": true,
    "noEmit": true,
    "resolveJsonModule": true,

    "module": "preserve",
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "isolatedDeclarations": true,
    "skipLibCheck": true,
    "moduleDetection": "force",
    "erasableSyntaxOnly": true,

    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "exclude": [
    "**/node_modules",
    "**/dist",
    "src/test/fixtures",
    "src/viewer/plots",
    "src/viewer/shell.ts",
    "src/viewer/Archive.ts",
    "src/viewer/DropZone.ts",
    "src/viewer/Helpers.ts",
    "src/viewer/Providers.ts",
    "src/viewer/ReportTab.ts",
    "src/viewer/SamplesTab.ts",
    "src/viewer/SourceTabs.ts",
    "src/viewer/TabSwitcher.ts",
    "*.config.ts"
  ]
}
